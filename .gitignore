# Editor / OS
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
*.iml

# Drafts and scratch
*.draft.md
scratch/
.scratch/

# Rust build artifacts
target/
**/target/
Cargo.lock.bak
*.rs.bk

# Note: Cargo.lock IS committed for the workspace per D0018 §7.4
# (reproducible builds depend on this)
# fuzz/Cargo.lock is also committed.

# Fuzz artifacts (corpus IS committed; minimization artifacts are not)
fuzz/artifacts/
fuzz/coverage/

# Android
android/.gradle/
android/build/
android/local.properties
android/.cxx/
android/**/build/
*.apk
*.aab
*.so.dwp
android/**/jniLibs/

# Nix
result
result-*
.direnv/

# Python (for any tooling scripts)
__pycache__/
*.pyc

# Audit and security tooling
.cargo/credentials.toml
.cargo/credentials

# Node (for any tooling)
node_modules/
dist/
build/

# Backup files
*.bak
*.orig

# Secret-bearing files (NEVER commit)
*.pem
*.key
*.p12
*.jks
*.keystore
secrets.local.*
.env
.env.*
!.env.example
# EXCEPTION: Sigstore *staging* test vectors are PUBLIC X.509 certificates +
# log SPKI public keys — NO private-key material (the `*.pem` here are certs
# / pubkeys only). They are intentional checked-in fixtures the offline
# real-data tests `include_str!` (tests/{fulcio,rekor}-staging/), so the
# `*.pem` guard above must NOT silently drop them. Scoped to this one tree;
# the broad guard still protects every other path.
!crates/cairn-sigstore-verify/tests/vectors/**/*.pem
