<resources>
    <!-- NoActionBar: Cairn is a pure-Compose app and draws its own Material3
         top app bar, so the platform ActionBar (which otherwise renders the
         android:label and produced a redundant second "Cairn" title) is off.
         The status bar uses the brand teal so it merges with the top app bar. -->
    <style name="Theme.Cairn" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/cairn_teal</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
